rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Fields: uid, email, displayName, role, kycStatus, phoneNumber, createdAt
    //
    // Collection: matters
    // Fields: title, description, clientId, department, status, nextCourtDate, lastUpdate, createdAt
    //
    // Collection: bookings
    // Fields: clientId, department, date, status, notes
    //
    // Collection: invoices
    // Fields: clientId, matterId, amount, status, dueDate, description, createdAt
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isStaff() {
      return isAuthenticated() && (getUserData().role == 'staff' || getUserData().role == 'admin');
    }

    function isAdmin() {
      return isAuthenticated() && (getUserData().role == 'admin' || (request.auth.token.email == "Kalalukainfo@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role']) &&
             data.uid is string &&
             data.email is string &&
             data.role in ['client', 'staff', 'admin'];
    }

    function isValidMatter(data) {
      return data.keys().hasAll(['title', 'clientId', 'department', 'status']) &&
             data.title is string && data.title.size() < 200 &&
             data.clientId is string &&
             data.department in ["Corporate Law", "Dispute Resolution", "Real Estate", "Intellectual Property", "Family Law"] &&
             data.status in ["Open", "In Progress", "Court Stage", "Closed"];
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isStaff();
      allow create: if isAuthenticated() && isValidUser(request.resource.data) && (isOwner(userId) || isAdmin());
      allow update: if isAuthenticated() && isValidUser(request.resource.data) && (isOwner(userId) || isAdmin()) && 
                    (request.resource.data.role == resource.data.role || isAdmin());
    }

    match /matters/{matterId} {
      allow read: if isStaff() || (isAuthenticated() && resource.data.clientId == request.auth.uid);
      allow create: if isStaff() && isValidMatter(request.resource.data);
      allow update: if isStaff() && isValidMatter(request.resource.data);
      allow delete: if isAdmin();

      match /documents/{docId} {
        allow read: if isStaff() || (isAuthenticated() && get(/databases/$(database)/documents/matters/$(matterId)).data.clientId == request.auth.uid);
        allow create: if isAuthenticated() && (isStaff() || get(/databases/$(database)/documents/matters/$(matterId)).data.clientId == request.auth.uid);
      }

      match /messages/{msgId} {
        allow read: if isStaff() || (isAuthenticated() && get(/databases/$(database)/documents/matters/$(matterId)).data.clientId == request.auth.uid);
        allow create: if isAuthenticated() && (isStaff() || get(/databases/$(database)/documents/matters/$(matterId)).data.clientId == request.auth.uid);
      }
    }

    match /bookings/{bookingId} {
      allow read: if isStaff() || (isAuthenticated() && resource.data.clientId == request.auth.uid);
      allow create: if isAuthenticated() && request.resource.data.clientId == request.auth.uid;
      allow update: if isStaff() || (isAuthenticated() && resource.data.clientId == request.auth.uid);
    }

    match /invoices/{invoiceId} {
      allow read: if isStaff() || (isAuthenticated() && resource.data.clientId == request.auth.uid);
      allow create, update: if isStaff();
    }
  }
}
